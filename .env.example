# Environment Configuration Template
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# Application
APP_NAME="Portfolio Platform"
APP_URL=https://portfolio-platform.com
APP_TIMEZONE=UTC
APP_SECRET_KEY=generate-a-random-32-character-secret-key-here

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=portfolio_platform
DB_USERNAME=portfolio_user
DB_PASSWORD=secure-database-password-here

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=noreply@portfolio-platform.com
SMTP_PASSWORD=secure-smtp-password-here
MAIL_FROM_ADDRESS=noreply@portfolio-platform.com
MAIL_FROM_NAME="Portfolio Platform"

# File Storage Paths (absolute paths)
UPLOAD_PATH=/var/www/portfolio-platform/uploads
THUMBNAIL_PATH=/var/www/portfolio-platform/uploads/thumbnails
TEMP_PATH=/var/www/portfolio-platform/temp
LOG_PATH=/var/www/portfolio-platform/logs
CACHE_PATH=/var/www/portfolio-platform/cache
